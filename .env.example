# =============================================================================
# OpenQwnt / Project Prometheus — complete env reference
# -----------------------------------------------------------------------------
# Copy to `.env` and fill in the values you actually need. Every variable is
# documented below with a link to where to obtain it and which feature it
# unlocks. Keys that are absolutely required for the app to run are marked
# [REQUIRED]; everything else is [OPTIONAL] (the feature behind it will be
# skipped or fall back to a mock/public source if the key is missing).
#
# The matching backend/.env file mirrors the server-side keys — the frontend
# only needs the VITE_* entries here.
# =============================================================================

# ============================================================================
# 1. Frontend (Vite) — always read at build time
# ============================================================================

# [REQUIRED] Supabase project (auth + user profiles). Create at
# https://supabase.com/dashboard → pick the project → Settings → API
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
VITE_SUPABASE_URL=https://your-project.supabase.co

# [REQUIRED] URLs the SPA uses to reach the local stack. The defaults match
# the docker-compose / local-dev setup.
VITE_ORCHESTRATOR_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
VITE_BACKEND_URL=http://localhost:8000


# ============================================================================
# 2. LLM providers (AI strategy generation, agent chat, terminal agents)
# ============================================================================

# [REQUIRED] Google Gemini — AI strategy generation, ADK agents, AI assistant
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# [REQUIRED] DeepSeek — backup / cheaper LLM used by strategy validator
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# [OPTIONAL] OpenAI — used as an alternate LLM provider (tool_calling.py)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# [OPTIONAL] Anthropic — alternate LLM provider
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# [OPTIONAL] Lovable AI Gateway — legacy Gemini proxy used by the legacy
# strategy-generation path. Free trials are available at https://lovable.dev
AI_GATEWAY_API_KEY=


# ============================================================================
# 3. Market data providers (prices, fundamentals, holders, supply chain)
# ============================================================================
# In priority order. Most terminal functions (DES, GIP, HDS, SPLC, BMAP) will
# work with just yfinance (free, already installed, no key). The rest raise
# coverage + quality.

# [OPTIONAL] Financial Modeling Prep — deep fundamentals, 13F (Ultimate tier),
# supply-chain peers, stock screener. Free tier = 250 calls/day.
# https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=done

# [OPTIONAL] Alpha Vantage — alternate fundamentals + intraday (5 calls/min free)
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=done

# [OPTIONAL] Finnhub — real-time quotes, SEC filings, earnings (60 calls/min free)
# https://finnhub.io/dashboard
FINNHUB_API_KEY=done

# [OPTIONAL] Polygon.io — institutional-grade US equities + options data
# https://polygon.io/dashboard/api-keys
POLYGON_API_KEY=done

# [OPTIONAL] FRED — macro data (CPI, GDP, rates). Free with signup.
# https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=done

# [OPTIONAL] NewsAPI — consumer news headlines (100 req/day free)
# https://newsapi.org/register
NEWSAPI_KEY=done


# ============================================================================
# 4. Broker APIs (live trading)
# ============================================================================

# [OPTIONAL] IG Markets — CFDs, FX, spread betting
# https://labs.ig.com/gettingstarted (demo account is free)
IG_API_KEY=
IG_USERNAME=
IG_PASSWORD=
IG_ACCOUNT_TYPE=DEMO

# [OPTIONAL] Alpaca — commission-free US stocks + crypto paper / live
# https://app.alpaca.markets/paper/dashboard/overview → API Keys
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
AlPACA_ENDPOINT=https://paper-api.alpaca.markets/v2

# [OPTIONAL] Binance — crypto spot + futures
# https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_API_SECRET=

# [OPTIONAL] Nordnet NEXTAPI — Swedish/Nordic retail broker (public stocks)
# https://www.nordnet.se/se/kundservice/api
# Requires generating an Ed25519 key pair and uploading the public key at
# "Min Säkerhet". Paste the PRIVATE key here (PEM or base64).
NORDNET_API_KEY=
NORDNET_PRIVATE_KEY=

# [OPTIONAL] Interactive Brokers — Client Portal API (OAuth gateway flow)
# https://www.interactivebrokers.com/en/trading/ib-api.php
IBKR_GATEWAY_URL=
IBKR_ACCOUNT_ID=


# ============================================================================
# 5. Notifications (HITL alerts, trade confirmations)
# ============================================================================

# [OPTIONAL] Telegram bot — @BotFather on Telegram
# https://core.telegram.org/bots#how-do-i-create-a-bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# [OPTIONAL] Slack — https://api.slack.com/apps → create → OAuth & Permissions
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=

# [OPTIONAL] Discord — Server settings → Integrations → Webhooks
DISCORD_BOT_WEBHOOK_URL=

# [OPTIONAL] Twilio — SMS notifications
# https://console.twilio.com (free trial credits available)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# [OPTIONAL] SendGrid — email alerts
# https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
EMAIL_FROM_ADDRESS=noreply@strategyflow.app


# ============================================================================
# 6. Research / agent connectors
# ============================================================================

# [OPTIONAL] Firecrawl — turns any URL into LLM-ready markdown; used by the
# research agent's `scrape_url_text` tool.
# https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=done

# [OPTIONAL] Perplexity — AI-assisted web research (used by research agent)
# https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# [OPTIONAL] Tavily — web search API, friendlier than raw Google CSE
# https://app.tavily.com/
TAVILY_API_KEY=

# [OPTIONAL] Google Custom Search — fallback web search
# https://programmablesearchengine.google.com/
GOOGLE_CSE_ID=
GOOGLE_CSE_API_KEY=

# [OPTIONAL] Brave Search — privacy-friendly web search
# https://api.search.brave.com/app/keys
BRAVE_SEARCH_API_KEY=

# [OPTIONAL] TradingView webhooks (inbound alerts) — you set this secret; any
# TradingView alert pointing at /webhooks/tradingview must include it.
TRADINGVIEW_WEBHOOK_SECRET=


# ============================================================================
# 7. Orchestrator infra secrets (Node.js service)
# ============================================================================

# [REQUIRED in prod] Change these from the defaults below. They sign user
# sessions and encrypt broker credentials stored in the DB.
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
ENCRYPTION_KEY=dev-encryption-key-32-chars-long!


# ============================================================================
# 8. Feature flags / behaviour toggles
# ============================================================================

# When true, the block catalog is resolved via ChromaDB RAG instead of the
# hand-curated JSON map. Turn on once vectors are warm.
USE_RAG_FOR_BLOCKS=false

# When true, every Gemini call is re-routed to DeepSeek (cost control / testing).
USE_DEEPSEEK_ONLY=false

# Default yfinance session impersonation (helps dodge rate limits in 2026).
YFINANCE_IMPERSONATE=chrome

# Mapbox GL JS — get a free token at https://account.mapbox.com
VITE_MAPBOX_TOKEN=***REMOVED***
