# =============================================================================
# Frontend build context. Keep this lean — anything that lands in the
# build context is uploaded to the daemon on every `docker build`.
# =============================================================================

# Version control
.git
.gitignore
.github

# Node
node_modules
npm-debug.log*
yarn-error.log
pnpm-debug.log

# Build outputs
dist
dist-ssr
build
.vite

# IDE / OS
.idea
.vscode
.DS_Store
*.swp
*.swo

# Environment
.env
.env.local
.env.*.local

# Reference dirs (legacy, large)
openclaw-reference
n8n-reference
orchestrator

# Backend tree (the frontend image doesn't need it)
backend
agents
docs
e2e

# Phase result docs / planning
PLAN.md
PHASE_*.md
AUDIT.md
