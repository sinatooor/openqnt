{
  "name": "openqwnt",
  "private": true,
  "version": "1.0.0",
  "description": "OpenQnt — desktop trading platform",
  "type": "module",
  "main": "electron/dist/main.js",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "test": "vitest",
    "preview": "vite preview",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "codemod:runtime-urls": "bun run scripts/codemod-runtime-urls.ts",
    "extract-handles": "bun run scripts/extract-handle-configs.ts",
    "electron:tsc": "tsc -p electron/tsconfig.json && echo '{\"type\":\"commonjs\"}' > electron/dist/package.json",
    "electron:tsc:watch": "tsc -p electron/tsconfig.json --watch",
    "electron:dev": "concurrently -k -n vite,tsc,electron 'bun run dev' 'bun run electron:tsc:watch' 'wait-on http://localhost:5173 && electron electron/dist/main.js --dev'",
    "electron:bundle-python": "bash electron/scripts/bundle-python.sh",
    "electron:bundle-orchestrator": "bash electron/scripts/bundle-orchestrator.sh",
    "electron:bundle-strategy-ai": "bash electron/scripts/bundle-strategy-ai.sh",
    "electron:bundle-postgres": "bash electron/scripts/bundle-postgres.sh",
    "electron:bundle-redis": "bash electron/scripts/bundle-redis.sh",
    "electron:bundle-frontend": "OPENQWNT_DESKTOP_BUILD=true bun run build && rm -rf resources/frontend && mkdir -p resources/frontend && cp -R dist/. resources/frontend/",
    "electron:bundle-backend": "rm -rf resources/backend && rsync -a --exclude=__pycache__ --exclude='*.pyc' --exclude=tests --exclude=logs --exclude='*.log' --exclude='_telemetry' --exclude='_cache' --exclude='_backtests' --exclude='_execution' --exclude='chroma_db*' --exclude='strategies.db' --exclude='backend.log' --exclude=adk_workspace --exclude=test_*.py --exclude=quick_test.py --exclude='*_LEGACY*' --exclude='.env' --exclude='.env.local' --exclude='.env.*.local' backend/ resources/backend/",
    "electron:bundle-all": "bun run electron:bundle-python && bun run electron:bundle-postgres && bun run electron:bundle-redis && bun run electron:bundle-orchestrator && bun run electron:bundle-strategy-ai && bun run electron:bundle-backend && bun run electron:bundle-frontend",
    "electron:build": "bun run electron:tsc",
    "electron:dist": "bun run electron:bundle-all && bun run electron:build && electron-builder --config electron/electron-builder.yml --mac"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^3.10.0",
    "@monaco-editor/react": "^4.7.0",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@radix-ui/themes": "^3.2.1",
    "@tanstack/react-query": "^5.83.0",
    "@xyflow/react": "^12.10.0",
    "antd": "^6.3.0",
    "blockly": "^12.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "embla-carousel-react": "^8.6.0",
    "flexlayout-react": "^0.8.17",
    "framer-motion": "^12.23.25",
    "input-otp": "^1.4.2",
    "lightweight-charts": "^5.0.9",
    "lucide-react": "^0.462.0",
    "mapbox-gl": "^3.22.0",
    "next-themes": "^0.3.0",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-draggable": "^4.5.0",
    "react-grid-layout": "^2.2.3",
    "react-hook-form": "^7.61.1",
    "react-joyride": "^2.9.3",
    "react-map-gl": "^8.1.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.9",
    "react-router-dom": "^6.30.1",
    "recharts": "^2.15.4",
    "socket.io-client": "^4.8.3",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "technicalindicators": "^3.1.0",
    "vaul": "^0.9.9",
    "zod": "^3.25.76",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/react-grid-layout": "^1.3.6",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.0",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^7.2.4",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.1"
  }
}
