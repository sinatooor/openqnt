{
    "name": "strategyflow-orchestrator",
    "version": "1.0.0",
    "description": "StrategyFlow AI Agent — Node.js Orchestrator",
    "main": "dist/index.js",
    "scripts": {
        "dev": "bun --watch src/index.ts",
        "build": "tsc",
        "start": "bun dist/index.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint src/",
        "format": "prettier --write 'src/**/*.ts'",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:seed": "bun prisma/seed.ts",
        "db:studio": "prisma studio"
    },
    "dependencies": {
        "@bull-board/api": "^6.4.0",
        "@bull-board/express": "^6.4.0",
        "@prisma/client": "^6.3.0",
        "@sendgrid/mail": "^8.1.6",
        "@slack/web-api": "^7.14.1",
        "bcryptjs": "^2.4.3",
        "bullmq": "^5.34.0",
        "cors": "^2.8.5",
        "express": "^4.21.0",
        "express-rate-limit": "^7.4.0",
        "helmet": "^7.1.0",
        "ioredis": "^5.4.1",
        "jsonwebtoken": "^9.0.2",
        "node-telegram-bot-api": "^0.67.0",
        "pino": "^9.5.0",
        "pino-pretty": "^11.3.0",
        "rss-parser": "^3.13.0",
        "socket.io": "^4.8.0",
        "twilio": "^5.12.2",
        "uuid": "^10.0.0",
        "zod": "^3.23.0"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/node": "^22.0.0",
        "@types/node-telegram-bot-api": "^0.64.13",
        "@types/supertest": "^6.0.2",
        "@types/uuid": "^10.0.0",
        "eslint": "^9.0.0",
        "prettier": "^3.3.0",
        "prisma": "^6.3.0",
        "supertest": "^7.0.0",
        "typescript": "^5.6.0",
        "vitest": "^2.1.0"
    },
    "prisma": {
        "seed": "bun prisma/seed.ts"
    },
    "engines": {
        "bun": ">=1.0.0"
    }
}