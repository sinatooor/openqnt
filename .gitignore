# =============================================================================
# Logs
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =============================================================================
# Environment files (never commit secrets)
# =============================================================================
.env
.env.local
.env.*.local
backend/.env

# =============================================================================
# Node
# =============================================================================
node_modules/
dist/
dist-ssr/
.vite/
*.local

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.so
.Python
venv/
.venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
backend/venv/

# =============================================================================
# Per-user state — written by the platform, never committed
# (was accidentally tracked before; cleaned up via `git rm --cached`)
# =============================================================================
# Root-anchored: the runtime state dir only — NOT src/features/agents/ (an
# unanchored `agents/` silently ignored any new frontend file under it).
/agents/
# Copilot memory brain (runtime, per-user state). Root-anchored so it does NOT
# match the backend/memory/ SOURCE package.
/memory/

# =============================================================================
# Databases
# =============================================================================
*.db
*.sqlite
*.sqlite3

# =============================================================================
# Editor / IDE
# =============================================================================
.idea/
.vscode/*
!.vscode/extensions.json
.agent/
.bmad/
.claude/
.cursor/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# =============================================================================
# Reference / vendored trees (large, not part of the build)
# =============================================================================
n8n-reference/
openclaw-reference/
backend/twsapi_ib/

# =============================================================================
# One-off generated artifacts
# =============================================================================
test_nautilus_chart.html
test-results/
playwright-report/

# =============================================================================
# Electron desktop build outputs
#   - resources/  : staged tree the .app loads from (Python interp, Postgres,
#                   Redis, orchestrator binaries, frontend dist) — produced by
#                   `bun run electron:bundle-*`
#   - release/    : final .dmg / .zip artifacts written by electron-builder
# =============================================================================
resources/
release/

# =============================================================================
# Things we DO want tracked but the old gitignore was hiding:
#   - .github/   (CI workflows)
#   - docs/      (architecture.md, template docs)
# Make sure no stray rules above re-exclude them.
# =============================================================================
fame.html
nathenantony-line-ranges.txt
.gitignore
StrategyBuilderDemo.tsx

# =============================================================================
# Dev artifacts that should never be committed
# =============================================================================
# SQLite WAL/SHM sidecar files (generated alongside *.db)
backend/strategies.db
backend/*.db-shm
backend/*.db-wal
backend/*.db-journal
# mitmproxy captured traffic (multi-MB binary-ish data, regenerable)
scripts/avanza_capture.jsonl
# Firecrawl scratch dir
.firecrawl/
# Voice call transcripts (per-call JSONL, contains user PII)
backend/voice_transcripts/
# Mattpocock skills installer cache + lockfile (per-developer tooling)
.agents/
skills-lock.json
