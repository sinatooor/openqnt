# =============================================================================
# Backend (Python FastAPI) — server-side env vars
# =============================================================================
# This file mirrors the server-side keys from the top-level .env.example.
# The frontend ignores this file entirely — only the Python backend reads it.
# Every variable is OPTIONAL unless marked [REQUIRED]. Missing keys simply
# disable the corresponding feature.

# ── LLM providers ────────────────────────────────────────────
# [REQUIRED] Google Gemini — AI strategy generation, ADK agents, research
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# [REQUIRED] DeepSeek — backup / cheaper LLM used by the strategy validator
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Alternate LLM providers used by tool_calling.py / llm_service.py
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_GATEWAY_API_KEY=

# ── Market data providers (optional — yfinance is the fallback) ──
# https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=
# https://finnhub.io/dashboard
FINNHUB_API_KEY=
# https://polygon.io/dashboard/api-keys
POLYGON_API_KEY=
# https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=
# https://newsapi.org/register
NEWSAPI_KEY=

# ── Broker API credentials ──────────────────────────────────
# https://labs.ig.com/gettingstarted
IG_API_KEY=
IG_USERNAME=
IG_PASSWORD=
IG_ACCOUNT_TYPE=DEMO

# https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_API_SECRET=

# https://www.nordnet.se/se/kundservice/api
NORDNET_API_KEY=
NORDNET_PRIVATE_KEY=

# Interactive Brokers Client Portal Gateway
IBKR_GATEWAY_URL=
IBKR_ACCOUNT_ID=

# ── Research / scraping connectors ──────────────────────────
# https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=
# https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=
# https://app.tavily.com/
TAVILY_API_KEY=
# https://programmablesearchengine.google.com/
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
# https://api.search.brave.com/app/keys
BRAVE_SEARCH_API_KEY=
TRADINGVIEW_WEBHOOK_SECRET=

# ── Notifications ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=
DISCORD_BOT_WEBHOOK_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SENDGRID_API_KEY=
EMAIL_FROM_ADDRESS=noreply@strategyflow.app

# ── SEC EDGAR ───────────────────────────────────────────────
# SEC asks every automated request to identify itself. Replace the default
# below with "YourAppName (email@yourdomain.com)". No signup required.
SEC_USER_AGENT=OpenQwnt/1.0 (support@openqwnt.com)

# ── Feature flags ───────────────────────────────────────────
USE_RAG_FOR_BLOCKS=false
USE_DEEPSEEK_ONLY=false
YFINANCE_IMPERSONATE=chrome
